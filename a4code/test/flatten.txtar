-- input --

-- expected --
-- test: NewlinesOnly --
-- input --



-- expected --
-- test: MixedContentPreQuote --
-- input --
Prefix [quoteof "other" inner]
-- expected --
[quoteof "user" Prefix [quoteof "other" inner]]
-- test: MultipleNestedQuotesSameParagraph --
-- input --
[quoteof "A" 1] [quoteof "B" 2]
-- expected --
[quoteof "user" [quoteof "A" 1] [quoteof "B" 2]]
-- test: CaseInsensitiveFilter --
-- input --
[QUOTEOF "other" inner]
-- expected --
[quoteof "user" [QUOTEOF "other" inner]]
-- test: ParagraphStartingWithCloseBracket --
-- input --
]

Next
-- expected --
[quoteof "user" ]]



[quoteof "user" Next]
-- test: ParagraphStartingWithBackslash --
-- input --
\[

Next
-- expected --
[quoteof "user" []



[quoteof "user" Next]
-- test: UserExampleNestedQuote --
-- input --
Para 1

[quoteof "M" [quoteof "a" asdf]]

Para 2
-- expected --
[quoteof "user" Para 1]



[quoteof "a" asdf]



[quoteof "user" Para 2]
-- test: UserExampleNestedQuote_Rules_1 --
-- input --
[quote [quote text]]
-- expected --
[quote text]
-- test: UserExampleNestedQuote_Rules_2 --
-- input --
[quoteof "anotheruser" [quote text]]
-- expected --
[quoteof "anotheruser" [quote text]]
-- test: UserExampleNestedQuote_Rules_3 --
-- input --
[quote [quoteof "user" text]]
-- expected --
[quoteof "user" text]
-- test: UserExampleNestedQuote_Rules_4 --
-- input --
[quoteof "user2" [quoteof "user" text]]
-- expected --
[quoteof "user" text]
-- test: UserExampleNestedQuote_Rules_5 --
-- input --
[quoteof "user2" [quoteof "user" text] some more text]
-- expected --
[quoteof "user" text]
[quoteof "user2"  some more text]
