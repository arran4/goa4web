package templates

import "github.com/arran4/goa4web/core/common"

@Head(cd, $)

<h2>New Language</h2>
<form method="post">
    { csrfField }
    <label>Name:<input name="cname"></label>
    <input type="submit" name="task" value="Create Language">
</form>
<p><a href="/admin/languages">Back</a></p>
@Tail(cd, $)
