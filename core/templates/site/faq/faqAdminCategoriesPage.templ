package templates

import "github.com/arran4/goa4web/core/common"

@Head(cd, $)

<table>
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Question Count</th>
    </tr>
    for _, item := range .Rows {

    <tr>
        <td><a href="/admin/faq/categories/category/{ data.ID }">{ data.ID }</a></td>
        <td>{ data.Name.String }</td>
        <td>{ data.Questioncount }</td>
    </tr>
    }

</table>
<p><a href="/admin/faq/categories/new">Create Category</a></p>
@Tail(cd, $)
