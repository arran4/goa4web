package templates

import "github.com/arran4/goa4web/core/common"

@Head(cd, $)

<p>{ data.Message }</p>
<form method="post">
    { csrfField }
    <p><label><input type="checkbox" name="cascade" value="true"> Cascade Delete</label></p>
    <input type="submit" name="task" value="{ data.ConfirmLabel }">
</form>
<p><a href="{ data.Back }">Cancel</a></p>
@Tail(cd, $)
