<meta name="viewport" content="width=device-width, initial-scale=1">
<script src="/static/site.js?v=156b3e35806c203c"></script>
</head>
<body>
<header class="navbar">
<div class="navbar-left">
<label for="nav-toggle" class="hamburger" aria-label="Toggle navigation">
<span class="hamburger-icon" aria-hidden="true">&#9776;</span>
<span class="hamburger-text">Menu</span>
</label>
</div>
<div class="navbar-center">
<strong>
</strong>
</div>
<div class="navbar-right user-links">
<a href="/login?back=%2F">Login</a>
<a href="/register?back=%2F">Register</a>
</div>
</header>
<input type="checkbox" id="nav-toggle" class="nav-toggle">
<div class="layout">
<aside class="sidebar">
<hr>
<hr>
<a href="/item1">Item 1</a><br>
<div class="folded-toggle" data-target="folded-items">Advanced / Danger Zone</div>
<div id="folded-items" class="folded-items hidden">
<a href="/item2">Item 2</a><br>
</div>
</aside>
<main class="content">
Login:<br>
<form method="post" action="/login">
Username: <input name="username"><br>
Password: <input name="password" type="password"><br>
<input type="submit" name="task" value="Login">
<br><a href="/forgot">Forgot password?</a>
</form>
</main>
</div>
<div id="bottom"></div>
<hr>
<footer class="site-footer">
<div>
